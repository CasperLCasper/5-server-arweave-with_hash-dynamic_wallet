name: Update package-lock.json

on:
  workflow_dispatch:   # Ļauj jebkurā brīdī palaist manuāli ar pogu
  schedule:
    - cron: '0 0 * * 1'  # Automātiski palaidīsies katru pirmdienas rītu (00:00 UTC)

permissions:
  contents: write

jobs:
  update-lock:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      
      - uses: actions/setup-node@v5
        with:
          node-version: '22'
          
      # 🔥 ŠIS IR ĪSTAIS LABOJUMS:
      # Dzēšam veco lock failu, lai npm neredzētu veco 1.13.0 versiju,
      # un npx ncu pārbaudīs absolūti jaunāko reģistrā pieejamo versiju
      - name: Force rebuild package-lock from package.json
        run: |
          rm -f package-lock.json
          npx npm-check-updates -u
          npm install

      - name: Run npm audit fix
        run: npm audit fix --force || echo "Salabots viss, ko varēja"
      
      # Tagad git diff OBLIGĀTI pamanīs atšķirību (jo lock fails tiks pilnībā pārrakstīts)
      - name: Commit & Push updated package-lock.json
        run: |
          if git diff --exit-code package-lock.json package.json; then
            echo "Nav jaunu versiju, faili nav mainījušies."
          else
            echo "Atrasti atjauninājumi! Veicam saglabāšanu..."
            git config user.name "github-actions[bot]"
            git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
            
            # Pievienojam abus failus, jo npx ncu varēja atjaunināt arī package.json uz vēl jaunāku versiju
            git add package.json package-lock.json
            
            git commit -m "chore: auto-update dependencies and fix lockfile [skip ci]"
            git push origin HEAD:${{ github.ref_name }}
          fi
